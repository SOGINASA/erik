# Flask
FLASK_ENV=development
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-here

# Порт для локального запуска (python app.py). Должен совпадать с портом,
# на который стучит фронт (front/.env REACT_APP_API_URL, по умолчанию :5000).
PORT=5000

# База данных (без этой переменной создаётся локальный SQLite в database/)
# DATABASE_URL=sqlite:///database/database.db
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# CORS origins через запятую (без переменной — localhost:3000/5173).
# В проде укажите домен фронта, иначе браузер заблокирует запросы.
# CORS_ORIGINS=http://localhost:3000,https://myapp.example.com

# erik: базовый URL ссылки-приглашения erik.kz/g/<code>
SHARE_BASE_URL=https://erik.kz

# Базовый URL фронта — для ссылок в письмах (сброс пароля/верификация)
FRONTEND_URL=http://localhost:3000

# Почта (опционально). Без MAIL_SERVER письма не отправляются, а логируются (dev),
# а forgot-password в dev возвращает токен в ответе для проходимости флоу.
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=no-reply@erik.kz
# MAIL_PASSWORD=app-password
# MAIL_FROM=no-reply@erik.kz
